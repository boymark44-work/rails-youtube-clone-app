<h1 class="text-2xl font-bold mb-4">Notifications</h1>

<% if current_user.notifications.unread.any? %>
  <%= button_to "Mark All as Read", mark_all_read_notifications_path, method: :patch,
      class: "mb-4 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded" %>
<% end %>

<% if current_user.notifications.any? %>
  <ul class="space-y-3">
    <% current_user.notifications.order(created_at: :desc).each do |notification| %>
      <li class="border rounded p-4 <%= 'bg-gray-100' unless notification.read %>">
        
        <% if notification.notifiable_type == "Like" %>
            <% like = notification.notifiable %>
            <% if like && like.likeable.is_a?(Post) %>
                <p><strong><%= like.user.email %></strong> liked your video:</p>
                <%= link_to like.likeable.title, post_path(like.likeable), class: "text-blue-500" %>
            <% elsif like && like.likeable.is_a?(Comment) %>
                <p><strong><%= like.user.email %></strong> liked your comment:</p>
                <%= link_to "View Comment", post_path(like.likeable.post), class: "text-blue-500" %>
            <% else %>
                <p>No notifications.</p>
            <% end %>
        <% end %>
        
      </li>
    <% end %>
  </ul>
<% else %>
  <p>You have no notifications.</p>
<% end %>
