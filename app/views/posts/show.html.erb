<%= stylesheet_link_tag "application", "data-turbo-track": "reload", defer:true %>

<div class="grid lg:grid-cols-2 grid-cols-1 mt-4 px-4">
  <div class="youtube-layout">
    <% if @post.video.attached? %>
      <div class="video-container">
        <video controls>
          <source src="<%= url_for(@post.video) %>" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
      <h2 class="text-1xl post-details">
        Uploaded <%= time_ago_in_words(@post.created_at) %> ago
      </h2>
    <% else %>
      <% if @post.image.attached? %>
        <%= image_tag(@post.image, class: "thumbnail") %>
      <% end %>
    <% end %>
  </div>

  <div class="overlay xl:text-align:left;">
    <div class="overlay-content">
      <h2 class="text-5xl post-details"><%= @post.title %></h2>
      <h2 class="post-details">Description: <%= @post.description %></h2>
      <h2 class="post-details">Posted by: <%= @post.user.email %></h2>
      <h2 class="post-details"><%= @post.views %> views </h2>
    </div>
    <br>

    <div id="like-toggle">
      <%= turbo_frame_tag "like_toggle" do %>
        <% if current_user && @post.likes.exists?(user: current_user) %>
          <%= button_to post_like_path(@post), method: :delete, data: { turbo_frame: "like_toggle", class: "text-red-500" } do %>
            ❤️ Unlike (<%= @post.likes.count %>) <% end %>
        <% else %>
            <%= button_to post_like_path(@post), method: :post, data: { turbo_frame: "like_toggle" }, class: "text-gray-500" do %>
            🤍 Like (<%= @post.likes.count %>) <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="mt-4 flex gap-4 items-center">
      <% if @post.video.attached? || @post.image.attached? %>
        <%= link_to 'Download', download_post_path(@post), class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
      <% end %>

      <% if current_user && current_user.id == @post.user_id %>
        <%= link_to "Edit", edit_post_path(@post), 
              class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>

        <%= button_to "Delete", post_path(@post), 
              method: :delete,
              data: { confirm: "Are you sure you want to delete this post?" },
              class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
      <% end %>
    </div>
  </div>

  <div class="comment-section">
    <!-- This is from the helper, encapsulating the Ruby code from the helper to avoid messy and hard-to-maintain code -->
    <%#= render_comments(@post.comments.arrange) %>
    <%#= render 'comments/form', post: @post, parent: nil %>

    <h3 class="mt-6 text-lg">Leave a Comment</h3>
    <%= render 'comments/form', post: @post, parent: nil %>
    
    <!-- Display the total number of comments including replies --> 
    <h2 class="mt-6 text-xl fond-semibold mb-4"> <%= pluralize(@post.comments.count, "Comment") %></h2>

    <!-- Display the total number of root comments (Only parent comments, without the replies) -->
    <h2 class="mt-6 text-xl fond-semibold mb-4"> <%#= pluralize(@post.comments.root.count, "Comment") %></h2> 

    <div id="comments">
      <%= render_comments(@post.comments.arrange) %>
    </div>
  </div>
</div>

<style>
  .youtube-layout {
    width: 65%;
    margin: 0 auto;
  }

  .thumbnail {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
  }

  .post-details {
    padding: 10px;
  }

  .post-title {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 8px;
  }

  .post-details p {
    font-size: 14px;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio (change as needed) */
    padding-top: 30px;
    height: 0;
    overflow: hidden;
  }

  .video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .nested-comments {
  margin-left: 1.5rem;
  border-left: 2px solid #eee;
  padding-left: 1rem;
  }

</style>