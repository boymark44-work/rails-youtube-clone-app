<div class="page-container">

  <!-- Youtube Video -->
  <div class="youtube-layout">
    <% if @post.video.attached? %>
      <div class="video-container">
        <video controls>
          <source src="<%= url_for(@post.video) %>" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
      <h2 class="text-1xl post-details">
        Uploaded <%= time_ago_in_words(@post.created_at) %> ago
      </h2>
    <% else %>
      <% if @post.image.attached? %>
        <%= image_tag(@post.image, class: "thumbnail") %>
      <% end %>
    <% end %>
  </div>

  <!-- Post Details -->
  <div class="overlay xl:text-align:left;">
    <div class="overlay-content">
      <h2 class="text-5xl post-details"><%= @post.title %></h2>
      <h2 class="post-details">Description: <%= @post.description %></h2>
      <h2 class="post-details">Posted by: <%= @post.user.email %></h2>
      <h2 class="post-details"><%= @post.views %> views</h2>
    </div>

    <div id="like-toggle" class="mt-4">
      <%= turbo_frame_tag "like_toggle" do %>
        <% if current_user && @post.likes.exists?(user: current_user) %>
          <%= button_to post_like_path(@post), method: :delete, data: { turbo_frame: "like_toggle" } do %>
            ❤️ Unlike (<%= @post.likes.count %>)
          <% end %>
        <% else %>
          <%= button_to post_like_path(@post), method: :post, data: { turbo_frame: "like_toggle" } do %>
            🤍 Like (<%= @post.likes.count %>)
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="mt-4 flex gap-4 items-center flex-wrap">
      <% if @post.video.attached? || @post.image.attached? %>
        <%= link_to 'Download', download_post_path(@post), class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
      <% end %>

      <% if current_user && current_user.id == @post.user_id %>
        <%= link_to "Edit", edit_post_path(@post), class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
        <%= button_to "Delete", post_path(@post),
              method: :delete,
              data: { confirm: "Are you sure you want to delete this post?" },
              class: "rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
      <% end %>
    </div>
  </div>

  <!-- Comment Section -->
  <div class="comment-section">
    <h3 class="mt-6 text-2xl font-semibold mb-4">Leave a Comment</h3>
    <%= render 'comments/form', post: @post, parent: nil %>

    <h2 class="mt-6 text-xl font-semibold mb-4">
      <%= pluralize(@post.comments.count, "Comment") %>
    </h2>

    <div id="comments">
      <%= render_comments(@post.comments.arrange) %>
    </div>
  </div>

</div>

<!-- Updated CSS -->
<style>
  html, body {
    height: auto;
    min-height: 100%;
    overflow-y: auto; /* Important: allow vertical scroll */
  }

  .page-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
  }

  .youtube-layout {
    margin-bottom: 2rem;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  .video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .thumbnail {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
  }

  .post-details {
    padding: 10px 0;
  }

  .comment-section {
    margin-top: 2rem;
    background: #ffffff;
    padding: 2rem;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.05);
  }

  #comments {
    margin-top: 2rem;
    /* NO max-height here so page grows naturally */
  }

  .nested-comments {
    margin-left: 1.5rem;
    border-left: 2px solid #eee;
    padding-left: 1rem;
  }


  /* Beautiful Modern Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
  }

  /* Firefox specific scrollbar (optional but nice) */
  * {
    scrollbar-width: thin;
    scrollbar-color: #c1c1c1 #f1f1f1;
  }

</style>
