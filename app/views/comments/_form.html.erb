<%= form_with(model: [post, post.comments.new], local: true) do |f| %>
    <%= f.hidden_field :parent_id, value: parent.try(:id) %>
    <%= f.text_area :body, placeholder: "Write a comment....", rows: 2, class: "w-full p-2 rounded" %>
    <%= f.submit "Post", class: "mt-2 bg-blue-500 text-white px-4 py-2 rounded" %>
<% end %>