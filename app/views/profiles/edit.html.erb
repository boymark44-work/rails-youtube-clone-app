<!-- app/views/profiles/edit.html.erb -->
<h1 class="text-2xl font-bold mb-4">Profile</h1>

<% if @user.errors.any? %>
  <div class="error-messages">
    <h3><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h3>
    <ul>
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :email, "Email", class: "block mb-1 font-semibold" %>
    <%= f.email_field :email, class: "w-full border p-2 rounded" %>
  </div>

  <div>
    <%= f.label :first_name, "First Name", class: "block mb-1 font-semibold" %>
    <%= f.text_field :first_name, class: "w-full px-3 py-2 border rounded" %>
  </div>

  <div>
    <%= f.label :last_name, "Last Name", class: "block mb-1 font-semibold" %>
    <%= f.text_field :last_name, class: "w-full px-3 py-2 border rounded" %>
  </div>

  <div>
    <%= f.label :password, "New Password (leave blank if unchanged)", class: "block mb-1 font-semibold" %>
    <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3 py-2 border rounded" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "New Password Confirmation", class: "block mb-1 font-semibold" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3 py-2 border rounded" %>
  </div>

  <div>
    <%= f.label :current_password, "Current Password (required to change email or password)",class: "block mb-1 font-semibold" %>
    <%= f.password_field :current_password, autocomplete: "current-password",class: "w-full px-3 py-2 border rounded" %>
  </div>

  <div>
    <%= f.submit "Update Profile", class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 mb-10" %>
  </div>
<% end %>
